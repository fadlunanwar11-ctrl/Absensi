<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingVertical="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Waktu -->
        <LinearLayout
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/tvJamMulai"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="08:00"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#111827" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-"
                android:textSize="10sp"
                android:textColor="#9CA3AF"
                android:layout_marginVertical="2dp" />

            <TextView
                android:id="@+id/tvJamSelesai"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10:00"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#111827" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="50dp"
            android:background="#E5E7EB"
            android:layout_marginHorizontal="12dp" />

        <!-- Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvMapelJadwal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Matematika"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#111827" />

            <TextView
                android:id="@+id/tvGuruJadwal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Guru: Budi Santoso"
                android:textSize="11sp"
                android:textColor="#6B7280"
                android:layout_marginTop="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipHariJadwal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Senin"
                    android:textSize="10sp"
                    app:chipBackgroundColor="#DBEAFE"
                    android:textColor="#0369A1"
                    app:chipCornerRadius="12dp"
                    android:layout_marginEnd="6dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipRuangan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ruang 101"
                    android:textSize="10sp"
                    app:chipBackgroundColor="#F3F4F6"
                    android:textColor="#6B7280"
                    app:chipCornerRadius="12dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Action -->
        <ImageButton
            android:id="@+id/btnMenuJadwal"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_profile"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="centerInside"
            android:contentDescription="Menu" />
    </LinearLayout>
</LinearLayout>
