<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    android:layout_margin="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#FFFFFF">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvNamaKelasRekapAbsen"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kelas 1A"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#111827" />

                <TextView
                    android:id="@+id/tvJumlahSiswaKelas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="30 Santri"
                    android:textSize="11sp"
                    android:textColor="#6B7280"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipPersentaseKelas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="93%"
                android:textSize="12sp"
                app:chipBackgroundColor="#DBEAFE"
                android:textColor="#0369A1"
                app:chipCornerRadius="16dp" />
        </LinearLayout>

        <!-- Status Breakdown -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@android:drawable/ic_media_play"
                    android:backgroundTint="#10B981" />

                <TextView
                    android:id="@+id/tvCountHadirKelas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="28"
                    android:textSize="11sp"
                    android:textColor="#6B7280"
                    android:layout_marginStart="6dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@android:drawable/ic_media_play"
                    android:backgroundTint="#F59E0B" />

                <TextView
                    android:id="@+id/tvCountSakitKelas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1"
                    android:textSize="11sp"
                    android:textColor="#6B7280"
                    android:layout_marginStart="6dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@android:drawable/ic_media_play"
                    android:backgroundTint="#8B5CF6" />

                <TextView
                    android:id="@+id/tvCountIzinKelas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1"
                    android:textSize="11sp"
                    android:textColor="#6B7280"
                    android:layout_marginStart="6dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@android:drawable/ic_media_play"
                    android:backgroundTint="#EF4444" />

                <TextView
                    android:id="@+id/tvCountAlfaKelas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="11sp"
                    android:textColor="#6B7280"
                    android:layout_marginStart="6dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Action -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDetailRekapKelas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lihat Detail Kelas"
            android:textSize="12sp"
            app:cornerRadius="8dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
