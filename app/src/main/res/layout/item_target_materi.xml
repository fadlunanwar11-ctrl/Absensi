<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    android:layout_margin="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#FFFFFF">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvNamaMateri"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Persamaan Linear"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#111827" />

                <TextView
                    android:id="@+id/tvBab"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BAB 3 - Sub Topik"
                    android:textSize="12sp"
                    android:textColor="#6B7280"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Status Badge -->
            <com.google.android.material.chip.Chip
                android:id="@+id/chipStatusTarget"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Target"
                android:textSize="11sp"
                app:chipBackgroundColor="#FEF3C7"
                android:textColor="#92400E"
                app:chipCornerRadius="16dp" />
        </LinearLayout>

        <!-- Progress Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Progress"
                    android:textSize="12sp"
                    android:textColor="#6B7280" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/tvProgressPercentage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="75%"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#10B981" />
            </LinearLayout>

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:progress="75"
                android:progressDrawable="@android:drawable/progress_horizontal"
                style="@android:style/Widget.ProgressBar.Horizontal" />
        </LinearLayout>

        <!-- Detail Informasi -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Jam Mengajar"
                    android:textSize="11sp"
                    android:textColor="#9CA3AF" />

                <TextView
                    android:id="@+id/tvJamMengajar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="4 JP"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#111827"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Target Selesai"
                    android:textSize="11sp"
                    android:textColor="#9CA3AF" />

                <TextView
                    android:id="@+id/tvTargetSelesai"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="22 Juni 2026"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#111827"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kelas"
                    android:textSize="11sp"
                    android:textColor="#9CA3AF" />

                <TextView
                    android:id="@+id/tvKelas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kelas 1A"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#111827"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Action Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLaporProgressMateri"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lapor Progress"
            android:textSize="12sp"
            app:cornerRadius="8dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
