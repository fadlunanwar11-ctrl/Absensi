<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    android:layout_margin="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#FFFFFF">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvNamaSantriNilai"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ahmad Fauzan"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#111827" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp">

                    <TextView
                        android:id="@+id/tvNomorIndukNilai"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TI1024105"
                        android:textSize="11sp"
                        android:textColor="#6B7280" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" • "
                        android:textSize="11sp"
                        android:textColor="#D1D5DB"
                        android:layout_marginHorizontal="6dp" />

                    <TextView
                        android:id="@+id/tvRataRataNilai"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rata-rata: 82"
                        android:textSize="11sp"
                        android:textColor="#6B7280" />
                </LinearLayout>
            </LinearLayout>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipGradeNilai"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="B+"
                android:textSize="12sp"
                app:chipBackgroundColor="#DBEAFE"
                android:textColor="#0369A1"
                app:chipCornerRadius="16dp" />
        </LinearLayout>

        <!-- List Nilai per Mata Pelajaran -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="8dp">

            <!-- Row 1: Mapel 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="6dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Matematika"
                    android:textSize="12sp"
                    android:textColor="#111827" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="85"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#3B82F6"
                    android:layout_marginEnd="12dp" />

                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="A"
                    android:textSize="10sp"
                    app:chipBackgroundColor="#DBEAFE"
                    android:textColor="#0369A1"
                    app:chipCornerRadius="12dp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E5E7EB"
                android:layout_marginVertical="6dp" />

            <!-- Row 2: Mapel 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="6dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Bahasa Indonesia"
                    android:textSize="12sp"
                    android:textColor="#111827" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="78"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#3B82F6"
                    android:layout_marginEnd="12dp" />

                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="B+"
                    android:textSize="10sp"
                    app:chipBackgroundColor="#DBEAFE"
                    android:textColor="#0369A1"
                    app:chipCornerRadius="12dp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E5E7EB"
                android:layout_marginVertical="6dp" />

            <!-- Row 3: Mapel 3 (Kosong) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="6dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Ilmu Pengetahuan Alam"
                    android:textSize="12sp"
                    android:textColor="#111827" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#9CA3AF"
                    android:layout_marginEnd="12dp" />

                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="10sp"
                    app:chipBackgroundColor="#F3F4F6"
                    android:textColor="#9CA3AF"
                    app:chipCornerRadius="12dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Info -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Guru belum mengisi = kosong"
            android:textSize="10sp"
            android:textColor="#9CA3AF"
            android:layout_marginTop="8dp" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
