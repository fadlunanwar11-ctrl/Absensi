<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F9FAFB">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarTambahKelas"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:title="Tambah Kelas"
        app:titleTextColor="@color/black"
        android:background="#FFFFFF" />

    <!-- Form Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Nama Kelas -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nama Kelas"
                app:boxBackgroundMode="outline"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.MaterialEditText
                    android:id="@+id/etNamaKelas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:text="Kelas 1A" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Tingkat -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Tingkat"
                app:boxBackgroundMode="outline"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/spinnerTingkat"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:text="Tingkat 1" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Jumlah Siswa -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Jumlah Siswa"
                app:boxBackgroundMode="outline"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.MaterialEditText
                    android:id="@+id/etJumlahSiswa"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:text="30" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Tahun Ajaran -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Tahun Ajaran"
                app:boxBackgroundMode="outline"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.MaterialEditText
                    android:id="@+id/etTahunAjaran"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:text="2025/2026" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Ruangan -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Ruangan"
                app:boxBackgroundMode="outline"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.MaterialEditText
                    android:id="@+id/etRuangan"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:text="Ruang 101" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Keterangan -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Keterangan"
                app:boxBackgroundMode="outline"
                app:counterEnabled="true"
                app:counterMaxLength="200"
                android:layout_marginBottom="20dp">

                <com.google.android.material.textfield.MaterialEditText
                    android:id="@+id/etKeteranganKelas"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:inputType="textMultiLine"
                    android:gravity="top|start"
                    android:text="" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Info -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#EFF6FF"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_check"
                        android:scaleType="centerInside"
                        app:tint="#3B82F6"
                        android:layout_marginEnd="12dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Kelas akan dibuat dan dapat ditambahkan murid setelah disimpan"
                        android:textSize="12sp"
                        android:textColor="#0369A1" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBatalTambahKelas"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="BATAL"
            android:layout_marginEnd="8dp"
            app:cornerRadius="8dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSimpanTambahKelas"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="SIMPAN KELAS"
            app:cornerRadius="8dp" />
    </LinearLayout>
</LinearLayout>
