<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.anthropic.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F9FAFB">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarAdminRaport"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:title="Raport Santri"
        app:titleTextColor="@color/black"
        android:background="#FFFFFF" />

    <!-- Filter & Search -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="#FFFFFF"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Cari Santri / Kelas"
            app:startIconDrawable="@drawable/ic_profile"
            android:layout_marginEnd="8dp">

            <com.google.android.material.textfield.MaterialEditText
                android:id="@+id/etSearchRaport"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFilterKelasRaport"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kelas"
            app:cornerRadius="8dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
    </LinearLayout>

    <!-- List Santri dengan Raport Summary -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvRaportSantri"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        tools:listitem="@layout/item_raport_santri" />

</LinearLayout>
