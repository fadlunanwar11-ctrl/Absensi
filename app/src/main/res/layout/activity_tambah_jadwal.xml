<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F9FAFB">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarTambahJadwal"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:title="Tambah Jadwal"
        app:titleTextColor="@color/black"
        android:background="#FFFFFF" />

    <!-- Form Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Pilih Kelas -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Pilih Kelas"
                app:boxBackgroundMode="outline"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/spinnerKelasJadwal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:text="Kelas 1A" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Hari -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Hari"
                app:boxBackgroundMode="outline"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/spinnerHariJadwal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:text="Senin" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Jam Mulai -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Jam Mulai"
                app:boxBackgroundMode="outline"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.MaterialEditText
                    android:id="@+id/etJamMulaiJadwal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="time"
                    android:text="08:00" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Jam Selesai -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Jam Selesai"
                app:boxBackgroundMode="outline"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.MaterialEditText
                    android:id="@+id/etJamSelesaiJadwal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="time"
                    android:text="09:30" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Mata Pelajaran -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Mata Pelajaran"
                app:boxBackgroundMode="outline"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/spinnerMapelJadwal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:text="Matematika" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Guru Mapel -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Guru Mapel"
                app:boxBackgroundMode="outline"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/spinnerGuruMapelJadwal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:text="Budi Santoso" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Ruangan -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Ruangan"
                app:boxBackgroundMode="outline"
                android:layout_marginBottom="20dp">

                <com.google.android.material.textfield.MaterialEditText
                    android:id="@+id/etRuanganJadwal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:text="Ruang 101" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Info -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#EFF6FF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_check"
                        android:scaleType="centerInside"
                        app:tint="#3B82F6"
                        android:layout_marginEnd="12dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Jadwal akan disimpan dan dapat dilihat di menu jadwal"
                        android:textSize="12sp"
                        android:textColor="#0369A1" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBatalTambahJadwal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="BATAL"
            android:layout_marginEnd="8dp"
            app:cornerRadius="8dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSimpanTambahJadwal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="SIMPAN JADWAL"
            app:cornerRadius="8dp" />
    </LinearLayout>
</LinearLayout>
