<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    android:layout_margin="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#FFFFFF">

        <!-- Header: Nama & Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvNamaSantriHafalan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ahmad Fauzan"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#111827" />

                <TextView
                    android:id="@+id/tvNomorIndukHafalan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TI1024105"
                    android:textSize="11sp"
                    android:textColor="#6B7280"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipStatusHafalanWali"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lanjut"
                android:textSize="11sp"
                app:chipBackgroundColor="#DBEAFE"
                android:textColor="#0369A1"
                app:chipCornerRadius="16dp" />
        </LinearLayout>

        <!-- Progress Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hafalan Terakhir"
                    android:textSize="11sp"
                    android:textColor="#9CA3AF" />

                <TextView
                    android:id="@+id/tvHafalanTerakhir"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Surah Al-Baqarah, Ayat 1-5"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#111827"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tanggal Update"
                    android:textSize="11sp"
                    android:textColor="#9CA3AF" />

                <TextView
                    android:id="@+id/tvTglUpdateHafalan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="15 Juni 2026"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#111827"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Rincian Hafalan -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#F9FAFB">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rincian Hafalan"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#6B7280"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvRincianHafalanWali"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Hafalan dari Ayat 1 sampai Ayat 5 dengan lancar dan fasih. Lancar melafalkan setiap ayat dan memahami makna."
                    android:textSize="12sp"
                    android:textColor="#111827"
                    android:lineSpacingMultiplier="1.3" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Riwayat Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Entri"
                    android:textSize="11sp"
                    android:textColor="#9CA3AF" />

                <TextView
                    android:id="@+id/tvTotalEntriHafalan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="12"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#3B82F6"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lanjut"
                    android:textSize="11sp"
                    android:textColor="#9CA3AF" />

                <TextView
                    android:id="@+id/tvCountLanjut"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="10"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#10B981"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ngulang"
                    android:textSize="11sp"
                    android:textColor="#9CA3AF" />

                <TextView
                    android:id="@+id/tvCountNgulang"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#F59E0B"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Action -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLihatDetailHafalan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lihat Detail Lengkap"
            android:textSize="12sp"
            app:cornerRadius="8dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
