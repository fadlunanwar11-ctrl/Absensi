<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.anthropic.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F9FAFB">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarRekapAbsenMuridWali"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:title="Rekap Absen Murid"
        app:titleTextColor="@color/black"
        android:background="#FFFFFF" />

    <!-- Filter Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#FFFFFF"
        android:layout_marginBottom="8dp">

        <!-- Filter Kelas -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Pilih Kelas"
            app:boxBackgroundMode="outline"
            android:layout_marginBottom="12dp">

            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/spinnerKelasRekapAbsen"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:text="Semua Kelas" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Periode Tabs -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabPeriodeRekapMurid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:tabIndicatorColor="#3B82F6"
            app:tabIndicatorHeight="2dp"
            app:tabSelectedTextColor="#3B82F6"
            app:tabTextColor="#9CA3AF"
            app:tabMode="fixed">

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Minggu Ini" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bulan Ini" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Semester" />
        </com.google.android.material.tabs.TabLayout>
    </LinearLayout>

    <!-- Summary Stats -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:background="#FFFFFF"
        android:layout_marginBottom="8dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total"
                android:textSize="11sp"
                android:textColor="#9CA3AF" />

            <TextView
                android:id="@+id/tvTotalMuridRekapAbsen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="120"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#3B82F6"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hadir"
                android:textSize="11sp"
                android:textColor="#9CA3AF" />

            <TextView
                android:id="@+id/tvTotalHadirMurid"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="112"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#10B981"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Persentase"
                android:textSize="11sp"
                android:textColor="#9CA3AF" />

            <TextView
                android:id="@+id/tvPersentaseHadirMurid"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="93.3%"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#10B981"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tidak Hadir"
                android:textSize="11sp"
                android:textColor="#9CA3AF" />

            <TextView
                android:id="@+id/tvTotalTidakHadirMurid"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="8"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#F59E0B"
                android:layout_marginTop="4dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- List Rekap Absen per Kelas -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvRekapAbsenMuridPerKelas"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        tools:listitem="@layout/item_rekap_absen_kelas_wali" />

    <!-- Export Button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnExportRekapAbsenMurid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="EXPORT REKAP ABSEN"
            android:textSize="13sp"
            android:textStyle="bold"
            app:cornerRadius="8dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
    </LinearLayout>
</LinearLayout>
