<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    android:layout_margin="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#FFFFFF">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvJamKelas"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="08:00 - 09:30"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#111827" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" • "
                        android:textSize="13sp"
                        android:textColor="#D1D5DB"
                        android:layout_marginHorizontal="6dp" />

                    <TextView
                        android:id="@+id/tvJpKelas"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2 JP"
                        android:textSize="12sp"
                        android:textColor="#6B7280" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="6dp">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_profile"
                        app:tint="#9CA3AF" />

                    <TextView
                        android:id="@+id/tvMapelMonitor"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Matematika"
                        android:textSize="11sp"
                        android:textColor="#6B7280"
                        android:layout_marginStart="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" • "
                        android:textSize="11sp"
                        android:textColor="#D1D5DB"
                        android:layout_marginHorizontal="6dp" />

                    <TextView
                        android:id="@+id/tvKelasMonitor"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Kelas 1A"
                        android:textSize="11sp"
                        android:textColor="#6B7280" />
                </LinearLayout>
            </LinearLayout>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipStatusGuruMonitor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✓ Masuk"
                android:textSize="11sp"
                app:chipBackgroundColor="#DBEAFE"
                android:textColor="#0369A1"
                app:chipCornerRadius="16dp" />
        </LinearLayout>

        <!-- Guru Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#F9FAFB"
            android:padding="12dp"
            android:layout_marginHorizontal="-4dp"
            android:layout_marginBottom="12dp">

            <ImageView
                android:id="@+id/imgGuruMonitor"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/ic_profile"
                android:scaleType="centerCrop"
                android:background="#E5E7EB"
                android:layout_marginEnd="12dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvNamaGuruMonitor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Budi Santoso"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#111827" />

                <TextView
                    android:id="@+id/tvJamAbsenMonitor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Masuk pukul 07:50"
                    android:textSize="11sp"
                    android:textColor="#10B981"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Note -->
        <TextView
            android:id="@+id/tvCatatanMonitor"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📸 Ada bukti foto masuk kelas"
            android:textSize="10sp"
            android:textColor="#9CA3AF" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
