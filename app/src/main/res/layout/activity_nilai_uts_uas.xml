<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F9FAFB"
    android:paddingTop="0dp">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarNilaiAssessment"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:title="Nilai Penilaian Khusus"
        app:titleTextColor="@color/black"
        app:navigationIcon="?attr/homeAsUpIndicator" />

    <!-- Tab Selection: UTS / UAS -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabAssessmentType"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:tabIndicatorColor="#3B82F6"
        app:tabIndicatorHeight="3dp"
        app:tabSelectedTextColor="#3B82F6"
        app:tabTextColor="#9CA3AF">

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nilai UTS" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nilai UAS" />
    </com.google.android.material.tabs.TabLayout>

    <!-- Filter & Search -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:background="#FFFFFF"
        android:layout_marginBottom="8dp">

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Cari Santri"
            app:startIconDrawable="@drawable/ic_profile"
            app:boxBackgroundMode="outline">

            <com.google.android.material.textfield.MaterialEditText
                android:id="@+id/etSearchSantri"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>

    <!-- List Santri dengan Input Nilai -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvNilaiAssessment"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        tools:listitem="@layout/item_santri_nilai_assessment" />

    <!-- Button Simpan -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSimpanNilaiAssessment"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:text="SIMPAN NILAI"
        android:textSize="14sp"
        android:textStyle="bold"
        app:cornerRadius="12dp" />

</LinearLayout>
