<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    android:layout_margin="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:background="#FFFFFF">

        <!-- Thumbnail -->
        <ImageView
            android:id="@+id/imgThumbnailBukti"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:src="@drawable/ic_profile"
            android:scaleType="centerCrop"
            android:layout_marginEnd="12dp"
            android:background="#E5E7EB" />

        <!-- Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:id="@+id/tvTanggalBukti"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="15 Juni 2026"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#111827" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipStatusBukti"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Diterima"
                    android:textSize="10sp"
                    app:chipBackgroundColor="#DBEAFE"
                    android:textColor="#0369A1"
                    app:chipCornerRadius="16dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_profile"
                    app:tint="#9CA3AF" />

                <TextView
                    android:id="@+id/tvJamBukti"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="14:30"
                    android:textSize="11sp"
                    android:textColor="#6B7280"
                    android:layout_marginStart="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" • "
                    android:textSize="11sp"
                    android:textColor="#D1D5DB"
                    android:layout_marginHorizontal="6dp" />

                <TextView
                    android:id="@+id/tvFileSize"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1.2 MB"
                    android:textSize="11sp"
                    android:textColor="#6B7280" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvKeterangan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Foto di depan kelas saat mengajar"
                android:textSize="11sp"
                android:textColor="#9CA3AF" />
        </LinearLayout>

        <!-- Action Button -->
        <ImageButton
            android:id="@+id/btnMenuBukti"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_profile"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="centerInside"
            android:contentDescription="Menu" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
