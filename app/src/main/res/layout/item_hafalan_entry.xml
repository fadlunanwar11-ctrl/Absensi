<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    android:layout_margin="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#FFFFFF">

        <!-- Header: Nomer & Delete Button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tvNomorHafalan"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="No. 1"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#111827" />

            <ImageButton
                android:id="@+id/btnDeleteEntry"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_profile"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:scaleType="centerInside"
                android:contentDescription="Hapus" />
        </LinearLayout>

        <!-- Row 1: Tanggal & Hafalan Sampai -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <!-- Tanggal -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Tanggal"
                app:boxBackgroundMode="outline"
                android:layout_marginEnd="8dp">

                <com.google.android.material.textfield.MaterialEditText
                    android:id="@+id/etTanggal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="date"
                    android:text="2026-06-15" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Hafalan Sampai -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Hafalan Sampai"
                app:boxBackgroundMode="outline">

                <com.google.android.material.textfield.MaterialEditText
                    android:id="@+id/etHafalanSampai"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:text="Ayat 5" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- Row 2: Hafalan (MultiLine) -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Rincian Hafalan"
            app:boxBackgroundMode="outline"
            android:layout_marginBottom="12dp"
            app:counterEnabled="true"
            app:counterMaxLength="500">

            <com.google.android.material.textfield.MaterialEditText
                android:id="@+id/etRincianHafalan"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:inputType="textMultiLine"
                android:gravity="top|start"
                android:text="Hafalan dari Ayat 1 sampai Ayat 5 dengan lancar dan fasih" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Row 3: Status & Repeat -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Status: Lanjut / Ngulang -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Status"
                app:boxBackgroundMode="outline"
                android:layout_marginEnd="8dp">

                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/spinnerStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:text="Lanjut" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Tanggal Repeat (Jika Ngulang) -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Tgl Repeat"
                app:boxBackgroundMode="outline">

                <com.google.android.material.textfield.MaterialEditText
                    android:id="@+id/etTglRepeat"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="date"
                    android:text="2026-06-16" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
