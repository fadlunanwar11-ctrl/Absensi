<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.anthropic.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F9FAFB">

    <!-- Filter Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#FFFFFF"
        android:layout_marginBottom="8dp">

        <!-- Periode Tabs -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabPeriodeNilai"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:tabIndicatorColor="#3B82F6"
            app:tabIndicatorHeight="2dp"
            app:tabSelectedTextColor="#3B82F6"
            app:tabTextColor="#9CA3AF"
            app:tabMode="fixed">

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mingguan" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bulanan" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Semester" />
        </com.google.android.material.tabs.TabLayout>

        <!-- Filter Mata Pelajaran -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Semua Mata Pelajaran"
            app:startIconDrawable="@drawable/ic_profile"
            android:layout_marginTop="12dp">

            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/spinnerMataPelajaran"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none" />
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>

    <!-- Tabs: Per Santri atau Per Mata Pelajaran -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabViewModeNilai"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:tabIndicatorColor="#3B82F6"
        app:tabIndicatorHeight="2dp"
        app:tabSelectedTextColor="#3B82F6"
        app:tabTextColor="#9CA3AF"
        android:layout_marginBottom="8dp">

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Per Santri" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Per Mapel" />
    </com.google.android.material.tabs.TabLayout>

    <!-- List Rekap Nilai -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvRekapNilai"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        tools:listitem="@layout/item_rekap_nilai_santri" />

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/emptyStateRekapNilai"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        android:padding="32dp">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_check"
            android:scaleType="centerInside"
            app:tint="#D1D5DB"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Guru belum mengisi nilai"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#6B7280"
            android:gravity="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nilai akan muncul setelah guru mapel mengisinya"
            android:textSize="12sp"
            android:textColor="#9CA3AF"
            android:gravity="center"
            android:layout_marginTop="8dp" />
    </LinearLayout>
</LinearLayout>
