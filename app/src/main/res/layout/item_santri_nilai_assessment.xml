<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    android:layout_margin="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:background="#FFFFFF">

        <!-- Info Santri -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvNamaSantri"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ahmad Fauzan"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#111827" />

            <TextView
                android:id="@+id/tvNomorInduk"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TI1024105"
                android:textSize="12sp"
                android:textColor="#6B7280"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Input Nilai -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:hint="Nilai"
            app:boxBackgroundMode="outline"
            app:counterEnabled="true"
            app:counterMaxLength="3"
            android:layout_marginStart="12dp">

            <com.google.android.material.textfield.MaterialEditText
                android:id="@+id/etNilai"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:text="85" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Grade Badge -->
        <com.google.android.material.chip.Chip
            android:id="@+id/chipGrade"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="A"
            android:textSize="12sp"
            android:layout_marginStart="12dp"
            app:chipBackgroundColor="#DBEAFE"
            android:textColor="#0369A1"
            app:chipCornerRadius="16dp" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
