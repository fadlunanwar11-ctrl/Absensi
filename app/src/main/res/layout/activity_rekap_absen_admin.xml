<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.anthropic.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F9FAFB">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarRekapAbsenAdmin"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:title="Rekap Absen Murid"
        app:titleTextColor="@color/black"
        app:navigationIcon="?attr/homeAsUpIndicator" />

    <!-- Filter -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#FFFFFF"
        android:layout_marginBottom="8dp">

        <!-- Filter Kelas & Periode -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Kelas"
                app:startIconDrawable="@drawable/ic_profile"
                android:layout_marginEnd="8dp">

                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/spinnerKelasRekapAbsen"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:text="Semua Kelas" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Periode">

                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/spinnerPeriodeRekapAbsen"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:text="Bulan Ini" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- Date Range -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Dari"
                android:layout_marginEnd="8dp">

                <com.google.android.material.textfield.MaterialEditText
                    android:id="@+id/etTglDariRekapAbsen"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="date"
                    android:focusable="false" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Sampai">

                <com.google.android.material.textfield.MaterialEditText
                    android:id="@+id/etTglSampaiRekapAbsen"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="date"
                    android:focusable="false" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Summary Stats -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="#FFFFFF"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total Murid"
                android:textSize="10sp"
                android:textColor="#9CA3AF" />

            <TextView
                android:id="@+id/tvTotalMuridRekapAbsen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="450"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#3B82F6"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hadir"
                android:textSize="10sp"
                android:textColor="#9CA3AF" />

            <TextView
                android:id="@+id/tvTotalHadirRekapAbsen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="420"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#10B981"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sakit/Izin"
                android:textSize="10sp"
                android:textColor="#9CA3AF" />

            <TextView
                android:id="@+id/tvTotalSakitIzinRekapAbsen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="15"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#F59E0B"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Alfa"
                android:textSize="10sp"
                android:textColor="#9CA3AF" />

            <TextView
                android:id="@+id/tvTotalAlfaRekapAbsen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="15"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#EF4444"
                android:layout_marginTop="2dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- List Kelas dengan Breakdown -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvRekapAbsenPerKelas"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        tools:listitem="@layout/item_rekap_absen_admin_kelas" />

    <!-- Export Button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnExportRekapAbsenAdmin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="EXPORT (EXCEL)"
            android:textSize="13sp"
            android:textStyle="bold"
            app:cornerRadius="8dp" />
    </LinearLayout>

</LinearLayout>
