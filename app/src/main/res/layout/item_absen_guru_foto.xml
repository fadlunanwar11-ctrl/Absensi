<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    android:layout_margin="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF">

        <!-- Foto Bukti -->
        <ImageView
            android:id="@+id/imgBuktiGuruFoto"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:src="@drawable/ic_profile"
            android:scaleType="centerCrop"
            android:background="#E5E7EB" />

        <!-- Info Guru & Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvNamaGuruAbsen"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Budi Santoso"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#111827" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Matematika"
                            android:textSize="11sp"
                            android:textColor="#6B7280" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" • "
                            android:textSize="11sp"
                            android:textColor="#D1D5DB"
                            android:layout_marginHorizontal="6dp" />

                        <TextView
                            android:id="@+id/tvKelasAbsen"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Kelas 1A"
                            android:textSize="11sp"
                            android:textColor="#6B7280" />
                    </LinearLayout>
                </LinearLayout>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipStatusAbsenGuru"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pending"
                    android:textSize="10sp"
                    app:chipBackgroundColor="#FEF3C7"
                    android:textColor="#92400E"
                    app:chipCornerRadius="16dp" />
            </LinearLayout>

            <!-- Waktu -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_profile"
                    app:tint="#9CA3AF"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/tvTanggalWaktuAbsenGuru"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="15 Juni 2026 • 08:15"
                    android:textSize="12sp"
                    android:textColor="#6B7280" />
            </LinearLayout>

            <!-- Murid di Foto (Info) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="8dp"
                android:background="#F3F4F6"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_profile"
                    app:tint="#6B7280"
                    android:layout_marginEnd="8dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Terdeteksi Murid"
                        android:textSize="10sp"
                        android:textColor="#9CA3AF" />

                    <TextView
                        android:id="@+id/tvJumlahMuridTerdeteksi"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="28 dari 30 murid"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#111827"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E5E7EB"
                android:layout_marginBottom="12dp" />

            <!-- Action Buttons: Verify / Reject -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRejectAbsenGuru"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="TOLAK"
                    android:layout_marginEnd="8dp"
                    app:cornerRadius="8dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnVerifyAbsenGuru"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="VERIFIKASI"
                    app:cornerRadius="8dp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
