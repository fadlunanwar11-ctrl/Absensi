<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F9FAFB"
    android:paddingTop="0dp">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarTargetMateri"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:title="Target Materi"
        app:titleTextColor="@color/black"
        app:navigationIcon="?attr/homeAsUpIndicator" />

    <!-- Tabs: Minggu Ini / Bulan Ini -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabTargetPeriode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:tabIndicatorColor="#3B82F6"
        app:tabIndicatorHeight="3dp"
        app:tabSelectedTextColor="#3B82F6"
        app:tabTextColor="#9CA3AF">

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Target Minggu Ini" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Target Bulan Ini" />
    </com.google.android.material.tabs.TabLayout>

    <!-- Info Periode -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="#FFFFFF"
        android:layout_marginBottom="8dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Periode Aktif"
                android:textSize="12sp"
                android:textColor="#6B7280" />

            <TextView
                android:id="@+id/tvPeriodeTarget"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="15 - 22 Juni 2026"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#111827"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRefreshTarget"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Refresh"
            android:textSize="12sp"
            app:cornerRadius="8dp" />
    </LinearLayout>

    <!-- List Target Materi -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvTargetMateri"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        tools:listitem="@layout/item_target_materi" />

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/emptyStateTargetMateri"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        android:padding="32dp">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_check"
            android:scaleType="centerInside"
            app:tint="#D1D5DB"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tidak ada target materi"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#6B7280"
            android:gravity="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Admin akan mengatur target materi untuk periode ini"
            android:textSize="13sp"
            android:textColor="#9CA3AF"
            android:gravity="center"
            android:layout_marginTop="8dp" />
    </LinearLayout>

    <!-- Info Button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:background="#FFFFFF"
        android:layout_marginTop="8dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_check"
            android:scaleType="centerInside"
            app:tint="#3B82F6"
            android:layout_marginEnd="12dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Target materi diatur oleh Administrator. Anda dapat melihat dan melaporkan progress capaian materi."
            android:textSize="12sp"
            android:textColor="#6B7280" />
    </LinearLayout>
</LinearLayout>
